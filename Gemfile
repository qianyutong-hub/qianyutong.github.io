source "https://rubygems.org"

# 核心：使用兼容Ruby 4.0的Jekyll 4.4
gem "jekyll", "~> 4.4"

# Windows时区兼容
gem "tzinfo", ">= 1", "< 3"
gem "tzinfo-data"

# 模板需要的所有插件
group :jekyll_plugins do
  gem "jekyll-feed"
  gem 'jekyll-sitemap'
  gem "jekyll-paginate"
  gem "jekyll-gist"
  gem "jekyll-redirect-from"  # 新增：解决当前报错的插件
end